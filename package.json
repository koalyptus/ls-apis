{
  "name": "ls-apis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/aggregator",
    "packages/cli",
    "packages/shared",
    "packages/mcp-server"
  ],
  "keywords": [
    "api",
    "apis",
    "api-aggregator",
    "apis-aggregator",
    "api-aggregator-cli",
    "apis-aggregator-cli",
    "api-dataset",
    "apis-dataset",
    "api-list",
    "apis-list",
    "cli",
    "free",
    "public-api",
    "public-apis"
  ],
  "author": {
    "name": "koalyptus",
    "url": "https://github.com/koalyptus"
  },
  "license": "MIT",
  "scripts": {
    "test": "vitest run --coverage",
    "test:aggregator": "npm run test --workspace=@ls-apis/aggregator",
    "test:cli": "npm run test --workspace=@ls-apis/cli",
    "test:shared": "npm run test --workspace=@ls-apis/shared",
    "test:mcp": "npm run test --workspace=@ls-apis/mcp-server",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "aggregate": "cd packages/aggregator && npm run aggregate",
    "qa": "cd packages/aggregator && npx tsx src/qa/index.ts",
    "ls-apis": "cd packages/cli && npx tsx src/index.ts",
    "mcp": "cd packages/mcp-server && npx tsx src/index.ts",
    "build:mcp": "npm run build --workspace=@ls-apis/mcp-server"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
